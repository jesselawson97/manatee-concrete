---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  service: string;           // e.g. "Tenant Buildouts"
  serviceSlug: string;       // e.g. "tenant-buildout"
  city: string;              // e.g. "Sarasota"
  county: string;            // e.g. "Sarasota County"
  headline: string;
  subheadline: string;
  intro: string;
  body: string[];            // array of paragraphs
  bullets: string[];
  heroImage: string;
  heroAlt: string;
}

const { service, serviceSlug, city, county, headline, subheadline, intro, body, bullets, heroImage, heroAlt } = Astro.props;

const title = `${service} ${city} FL | Manatee Concrete`;
const description = `Manatee Concrete provides professional ${service.toLowerCase()} in ${city}, FL and throughout ${county}. Licensed commercial concrete contractor. Call 941-730-8491 for a free consultation.`;
const canonical = `https://manateeconcrete.com/${serviceSlug}-${city.toLowerCase()}`;

const faqs = [
  {
    q: `Do you only do commercial concrete work in ${city}?`,
    a: `Yes. Manatee Concrete focuses exclusively on commercial concrete projects throughout ${city} and ${county}. Our crews, equipment, and process are built for the scale and durability requirements of commercial work — parking lots, driveways, curb and gutter, sidewalks, and concrete repair.`
  },
  {
    q: `How long does commercial concrete take to cure before it can be used?`,
    a: `Concrete typically reaches enough strength for foot traffic in 24 to 48 hours and vehicle traffic in about 7 days, though it continues curing and gaining strength for roughly 28 days. We schedule pours and sequencing to minimize the disruption to your business during that window.`
  },
  {
    q: `Is concrete better than asphalt for a commercial parking lot or driveway?`,
    a: `For most commercial applications, concrete lasts significantly longer than asphalt — often 30+ years versus 15 to 20 — with far less ongoing maintenance. Concrete handles heavy and stationary loads better and holds up well in Florida's heat. We'll give you an honest recommendation based on your specific use and site conditions.`
  },
  {
    q: `Do you handle permitting for commercial concrete projects?`,
    a: `Yes. We handle permit drawings, applications, and inspections with the local building department so you don't have to. Our familiarity with ${county} requirements helps keep projects moving without unnecessary delays.`
  },
  {
    q: `Are you licensed and insured?`,
    a: `Yes. Manatee Concrete operates as a licensed commercial contractor in the state of Florida and carries general liability and workers' compensation coverage on every project. We can provide a certificate of insurance on request.`
  },
  {
    q: `Can you do the work without shutting down our business?`,
    a: `In most cases, yes. We plan phased pours, off-hours scheduling, and temporary access routing so your business keeps operating during construction. We'll walk through a plan with you before work begins.`
  },
  {
    q: `Do your sidewalks and ramps meet ADA requirements?`,
    a: `Yes. All of our commercial sidewalks, ramps, and parking areas are built to current ADA standards for slope, width, and detectable warnings — protecting you from compliance issues and liability.`
  },
  {
    q: `How long does a typical commercial concrete project take?`,
    a: `Timelines depend on scope, site conditions, and permitting, but most commercial concrete projects in ${city} run anywhere from a few days to a few weeks. We give you a realistic schedule up front in your proposal and keep you updated throughout.`
  }
];

const allServices = [
  { name: 'Parking Lots', slug: 'parking-lot' },
  { name: 'Concrete Driveways', slug: 'concrete-driveway' },
  { name: 'Curb & Gutter', slug: 'curb-gutter' },
  { name: 'Sidewalks', slug: 'sidewalk' },
  { name: 'Concrete Repair', slug: 'concrete-repair' }
];
const cityLower = city.toLowerCase();
const relatedServices = allServices.filter(s => s.slug !== serviceSlug);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${service} in ${city}, FL`,
  "provider": {
    "@type": "GeneralContractor",
    "name": "Manatee Concrete",
    "url": "https://manateeconcrete.com",
    "telephone": "+19417308491",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bradenton",
      "addressRegion": "FL",
      "addressCountry": "US"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": city,
    "containedInPlace": {
      "@type": "State",
      "name": "Florida"
    }
  },
  "description": description
};
---

<Base title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <Nav />

  <!-- Hero -->
  <section class="lp-hero">
    <div class="lp-hero-bg">
      <img src={heroImage} alt={heroAlt} loading="eager" />
    </div>
    <div class="lp-hero-overlay"></div>
    <div class="lp-hero-content container">
      <p class="hero-eyebrow">Commercial Contractor — {city}, FL</p>
      <h1>{headline}</h1>
      <p class="hero-sub">{subheadline}</p>
      <a href="#contact" class="btn btn-white">Get a Free Consultation</a>
    </div>
  </section>

  <!-- Intro -->
  <section class="lp-intro">
    <div class="container">
      <div class="lp-intro-inner">
        <div class="lp-intro-text">
          <span class="section-label">{service} in {city}</span>
          <h2>{service} Contractor Serving {city} &amp; {county}</h2>
          <p class="lp-lead">{intro}</p>
          {body.map(p => <p>{p}</p>)}
          <a href="#contact" class="btn btn-gold" style="margin-top:1.5rem">Start Your Project</a>
        </div>
        <div class="lp-bullets-box">
          <h3>What's Included</h3>
          <ul>
            {bullets.map(b => <li>{b}</li>)}
          </ul>
          <div class="lp-cta-box">
            <p>Ready to get started?</p>
            <a href="tel:9417308491">941-730-8491</a>
            <a href="#contact" class="btn btn-gold" style="margin-top:.75rem;width:100%;text-align:center">Request a Quote</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Manatee Concrete -->
  <section class="lp-why">
    <div class="container">
      <span class="section-label">Why Manatee Concrete</span>
      <h2>The {city} Commercial Concrete Contractor Built for Business</h2>
      <div class="lp-why-grid">
        <div class="lp-why-card">
          <h3>Licensed &amp; Insured</h3>
          <p>Licensed commercial contractor in the state of Florida. Full general liability and workers' comp on every project.</p>
        </div>
        <div class="lp-why-card">
          <h3>On Schedule</h3>
          <p>Concrete delays everything downstream. We set realistic timelines, hold to them, and coordinate with your other trades from day one.</p>
        </div>
        <div class="lp-why-card">
          <h3>Commercial Only</h3>
          <p>We don't do residential driveways. Every project we take on is commercial — our crews, equipment, and process are built for it.</p>
        </div>
        <div class="lp-why-card">
          <h3>Local to {city}</h3>
          <p>We know {county} permitting, local inspectors, and material suppliers. That local knowledge keeps projects moving without costly delays.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process (condensed) -->
  <section class="lp-process">
    <div class="container">
      <span class="section-label">How It Works</span>
      <h2>Simple. Transparent. Delivered.</h2>
      <div class="lp-process-steps">
        <div class="lp-step"><span>1</span><p>Free Consultation</p></div>
        <div class="lp-step"><span>2</span><p>Proposal &amp; Planning</p></div>
        <div class="lp-step"><span>3</span><p>Permits &amp; Preconstruction</p></div>
        <div class="lp-step"><span>4</span><p>Build &amp; Deliver</p></div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="lp-related">
    <div class="container">
      <span class="section-label">More Services in {city}</span>
      <h2>Other Commercial Concrete Services</h2>
      <div class="lp-related-grid">
        {relatedServices.map(s => (
          <a href={`/${s.slug}-${cityLower}`} class="lp-related-card">
            <span>{s.name} in {city}</span>
            <i>&rarr;</i>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="lp-faq">
    <div class="container">
      <span class="section-label">Common Questions</span>
      <h2>Frequently Asked Questions</h2>
      <div class="lp-faq-list">
        {faqs.map(f => (
          <details class="lp-faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-inner">
        <div class="contact-info">
          <span class="section-label">Let's Talk</span>
          <h2>{service} in {city} — Get a Free Quote</h2>
          <p>
            Tell us about your project and we'll reach out within one business day.
            No obligation, no pressure.
          </p>
          <div class="contact-detail">
            <strong>Phone:</strong> <span>941-730-8491</span>
          </div>
          <div class="contact-detail">
            <strong>Email:</strong> <span>projects@gulfwayconstruction.com</span>
          </div>
        </div>
        <form class="contact-form" method="POST" action="https://api.web3forms.com/submit">
          <input type="hidden" name="access_key" value="8e57c099-bf52-4809-b261-521a3afe7b05" />
          <input type="hidden" name="subject" value={`${service} Inquiry — ${city} | Manatee Concrete`} />
          <input type="hidden" name="redirect" value="https://manateeconcrete.com" />
          <input type="hidden" name="project-type" value={service} />
          <div class="form-row">
            <input type="text" name="first-name" placeholder="First Name" required />
            <input type="text" name="last-name" placeholder="Last Name" required />
          </div>
          <input type="email" name="email" placeholder="Email Address" required />
          <input type="tel" name="phone" placeholder="Phone Number" />
          <textarea name="message" placeholder={`Tell us about your ${service.toLowerCase()} project in ${city}…`}></textarea>
          <button type="submit">Send Message</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* Landing page hero */
.lp-hero {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: center;
}
.lp-hero-bg {
  position: absolute; inset: 0;
}
.lp-hero-bg img {
  width: 100%; height: 100%; object-fit: cover;
}
.lp-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(26,26,26,.80) 0%, rgba(26,26,26,.55) 100%);
}
.lp-hero-content {
  position: relative;
  z-index: 1;
  color: var(--white);
  padding-top: 120px;
  padding-bottom: 4rem;
}
.lp-hero-content h1 {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  line-height: 1.15;
  margin: .5rem 0 1rem;
}
.lp-hero-content .hero-eyebrow {
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--gold-lt);
}
.lp-hero-content .hero-sub {
  font-size: 1.1rem;
  max-width: 560px;
  margin-bottom: 2rem;
  opacity: .9;
}

/* Intro split */
.lp-intro { padding: 5rem 0; }
.lp-intro-inner {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 4rem;
  align-items: start;
}
.lp-intro-text h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin: .5rem 0 1.25rem;
}
.lp-lead {
  font-size: 1.1rem;
  color: var(--mid);
  margin-bottom: 1rem;
}
.lp-intro-text p { color: var(--mid); margin-bottom: .9rem; }

.lp-bullets-box {
  background: var(--light);
  border-left: 4px solid var(--gold);
  padding: 2rem;
  border-radius: var(--radius);
  position: sticky;
  top: 130px;
}
.lp-bullets-box h3 {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.lp-bullets-box ul {
  list-style: none;
  margin-bottom: 1.5rem;
}
.lp-bullets-box ul li {
  padding: .4rem 0 .4rem 1.4rem;
  position: relative;
  font-size: .95rem;
  color: var(--mid);
  border-bottom: 1px solid rgba(0,0,0,.07);
}
.lp-bullets-box ul li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: var(--gold);
  font-weight: 700;
}
.lp-cta-box {
  text-align: center;
  padding-top: 1.25rem;
}
.lp-cta-box p { font-size: .85rem; color: var(--mid); margin-bottom: .25rem; }
.lp-cta-box > a:first-of-type {
  display: block;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--gold);
  margin-bottom: .25rem;
}

/* Why grid */
.lp-why {
  background: var(--dark);
  color: var(--white);
  padding: 5rem 0;
}
.lp-why .section-label { color: var(--gold-lt); }
.lp-why h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin: .5rem 0 2.5rem;
}
.lp-why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 2rem;
}
.lp-why-card { border-top: 2px solid var(--gold); padding-top: 1.25rem; }
.lp-why-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: .6rem; }
.lp-why-card p { font-size: .9rem; color: rgba(255,255,255,.7); line-height: 1.65; }

/* Process bar */
.lp-process { padding: 4rem 0; background: var(--light); }
.lp-process h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  margin: .5rem 0 2.5rem;
}
.lp-process-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}
.lp-step {
  text-align: center;
  padding: 1.5rem 1rem;
  background: var(--white);
  border-radius: var(--radius);
  border-top: 3px solid var(--gold);
}
.lp-step span {
  display: block;
  font-size: 2rem;
  font-weight: 700;
  color: var(--gold);
  font-family: var(--font-serif);
  margin-bottom: .5rem;
}
.lp-step p { font-size: .85rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; }

/* Related services */
.lp-related { padding: 5rem 0; background: var(--light); }
.lp-related h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  margin: .5rem 0 2rem;
}
.lp-related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1rem;
}
.lp-related-card {
  background: var(--white);
  border-radius: var(--radius);
  border-left: 3px solid var(--gold);
  padding: 1.1rem 1.25rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: 600;
  font-size: .95rem;
  transition: transform .2s, box-shadow .2s;
}
.lp-related-card:hover { transform: translateX(3px); box-shadow: 0 4px 14px rgba(0,0,0,.08); }
.lp-related-card i { color: var(--gold); font-style: normal; font-size: 1.2rem; }

/* FAQ */
.lp-faq { padding: 5rem 0; }
.lp-faq h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin: .5rem 0 2.5rem;
}
.lp-faq-list { max-width: 820px; }
.lp-faq-item {
  border-bottom: 1px solid rgba(0,0,0,.1);
  padding: 1.1rem 0;
}
.lp-faq-item summary {
  font-size: 1.02rem;
  font-weight: 600;
  cursor: pointer;
  list-style: none;
  position: relative;
  padding-right: 2rem;
  color: var(--dark);
}
.lp-faq-item summary::-webkit-details-marker { display: none; }
.lp-faq-item summary::after {
  content: '+';
  position: absolute;
  right: 0;
  top: -2px;
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--gold);
  transition: transform .2s;
}
.lp-faq-item[open] summary::after { content: '\2212'; }
.lp-faq-item p {
  margin-top: .9rem;
  color: var(--mid);
  font-size: .95rem;
  line-height: 1.7;
}

/* Mobile */
@media (max-width: 860px) {
  .lp-intro-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  .lp-bullets-box { position: static; }
  .lp-process-steps { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .lp-process-steps { grid-template-columns: 1fr 1fr; }
}
</style>
