---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  service: string;           // e.g. "Tenant Buildouts"
  serviceSlug: string;       // e.g. "tenant-buildout"
  city: string;              // e.g. "Sarasota"
  county: string;            // e.g. "Sarasota County"
  headline: string;
  subheadline: string;
  intro: string;
  body: string[];            // array of paragraphs
  bullets: string[];
  heroImage: string;
  heroAlt: string;
}

const { service, serviceSlug, city, county, headline, subheadline, intro, body, bullets, heroImage, heroAlt } = Astro.props;

const title = `${service} ${city} FL | Gulfway Construction`;
const description = `Gulfway Construction provides professional ${service.toLowerCase()} in ${city}, FL and throughout ${county}. Licensed commercial contractor. Call 941-730-8491 for a free consultation.`;
const canonical = `https://manateeconcrete.com/${serviceSlug}-${city.toLowerCase()}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `${service} in ${city}, FL`,
  "provider": {
    "@type": "GeneralContractor",
    "name": "Manatee Concrete",
    "url": "https://manateeconcrete.com",
    "telephone": "+19417308491",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bradenton",
      "addressRegion": "FL",
      "addressCountry": "US"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": city,
    "containedInPlace": {
      "@type": "State",
      "name": "Florida"
    }
  },
  "description": description
};
---

<Base title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <Nav />

  <!-- Hero -->
  <section class="lp-hero">
    <div class="lp-hero-bg">
      <img src={heroImage} alt={heroAlt} loading="eager" />
    </div>
    <div class="lp-hero-overlay"></div>
    <div class="lp-hero-content container">
      <p class="hero-eyebrow">Commercial Contractor — {city}, FL</p>
      <h1>{headline}</h1>
      <p class="hero-sub">{subheadline}</p>
      <a href="#contact" class="btn btn-white">Get a Free Consultation</a>
    </div>
  </section>

  <!-- Intro -->
  <section class="lp-intro">
    <div class="container">
      <div class="lp-intro-inner">
        <div class="lp-intro-text">
          <span class="section-label">{service} in {city}</span>
          <h2>{service} Contractor Serving {city} &amp; {county}</h2>
          <p class="lp-lead">{intro}</p>
          {body.map(p => <p>{p}</p>)}
          <a href="#contact" class="btn btn-gold" style="margin-top:1.5rem">Start Your Project</a>
        </div>
        <div class="lp-bullets-box">
          <h3>What's Included</h3>
          <ul>
            {bullets.map(b => <li>{b}</li>)}
          </ul>
          <div class="lp-cta-box">
            <p>Ready to get started?</p>
            <a href="tel:9417308491">941-730-8491</a>
            <a href="#contact" class="btn btn-gold" style="margin-top:.75rem;width:100%;text-align:center">Request a Quote</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Gulfway -->
  <section class="lp-why">
    <div class="container">
      <span class="section-label">Why Gulfway</span>
      <h2>The {city} Commercial Contractor Built for Business</h2>
      <div class="lp-why-grid">
        <div class="lp-why-card">
          <h3>Licensed &amp; Insured</h3>
          <p>Certified Building Contractor (CBC) licensed in the state of Florida. Full general liability and workers' comp on every project.</p>
        </div>
        <div class="lp-why-card">
          <h3>On Time, On Budget</h3>
          <p>We set realistic schedules and hold to them. Transparent cost-plus or fixed-price proposals so there are no surprises at closeout.</p>
        </div>
        <div class="lp-why-card">
          <h3>Commercial Only</h3>
          <p>We don't split our focus. Every project we take on is commercial — so our process, subs, and expertise are purpose-built for business spaces.</p>
        </div>
        <div class="lp-why-card">
          <h3>Local to {city}</h3>
          <p>We know {county} permitting, local inspectors, and the subcontractor network. That local knowledge keeps projects moving without costly delays.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process (condensed) -->
  <section class="lp-process">
    <div class="container">
      <span class="section-label">How It Works</span>
      <h2>Simple. Transparent. Delivered.</h2>
      <div class="lp-process-steps">
        <div class="lp-step"><span>1</span><p>Free Consultation</p></div>
        <div class="lp-step"><span>2</span><p>Proposal &amp; Planning</p></div>
        <div class="lp-step"><span>3</span><p>Permits &amp; Preconstruction</p></div>
        <div class="lp-step"><span>4</span><p>Build &amp; Deliver</p></div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-inner">
        <div class="contact-info">
          <span class="section-label">Let's Talk</span>
          <h2>{service} in {city} — Get a Free Quote</h2>
          <p>
            Tell us about your project and we'll reach out within one business day.
            No obligation, no pressure.
          </p>
          <div class="contact-detail">
            <strong>Phone:</strong> <span>941-730-8491</span>
          </div>
          <div class="contact-detail">
            <strong>Email:</strong> <span>projects@gulfwayconstruction.com</span>
          </div>
        </div>
        <form class="contact-form" method="POST" action="https://api.web3forms.com/submit">
          <input type="hidden" name="access_key" value="8e57c099-bf52-4809-b261-521a3afe7b05" />
          <input type="hidden" name="subject" value={`${service} Inquiry — ${city} | Manatee Concrete`} />
          <input type="hidden" name="redirect" value="https://manateeconcrete.com" />
          <input type="hidden" name="project-type" value={service} />
          <div class="form-row">
            <input type="text" name="first-name" placeholder="First Name" required />
            <input type="text" name="last-name" placeholder="Last Name" required />
          </div>
          <input type="email" name="email" placeholder="Email Address" required />
          <input type="tel" name="phone" placeholder="Phone Number" />
          <textarea name="message" placeholder={`Tell us about your ${service.toLowerCase()} project in ${city}…`}></textarea>
          <button type="submit">Send Message</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<style>
/* Landing page hero */
.lp-hero {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: center;
}
.lp-hero-bg {
  position: absolute; inset: 0;
}
.lp-hero-bg img {
  width: 100%; height: 100%; object-fit: cover;
}
.lp-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(26,26,26,.80) 0%, rgba(26,26,26,.55) 100%);
}
.lp-hero-content {
  position: relative;
  z-index: 1;
  color: var(--white);
  padding-top: 120px;
  padding-bottom: 4rem;
}
.lp-hero-content h1 {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  line-height: 1.15;
  margin: .5rem 0 1rem;
}
.lp-hero-content .hero-eyebrow {
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--gold-lt);
}
.lp-hero-content .hero-sub {
  font-size: 1.1rem;
  max-width: 560px;
  margin-bottom: 2rem;
  opacity: .9;
}

/* Intro split */
.lp-intro { padding: 5rem 0; }
.lp-intro-inner {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 4rem;
  align-items: start;
}
.lp-intro-text h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin: .5rem 0 1.25rem;
}
.lp-lead {
  font-size: 1.1rem;
  color: var(--mid);
  margin-bottom: 1rem;
}
.lp-intro-text p { color: var(--mid); margin-bottom: .9rem; }

.lp-bullets-box {
  background: var(--light);
  border-left: 4px solid var(--gold);
  padding: 2rem;
  border-radius: var(--radius);
  position: sticky;
  top: 130px;
}
.lp-bullets-box h3 {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.lp-bullets-box ul {
  list-style: none;
  margin-bottom: 1.5rem;
}
.lp-bullets-box ul li {
  padding: .4rem 0 .4rem 1.4rem;
  position: relative;
  font-size: .95rem;
  color: var(--mid);
  border-bottom: 1px solid rgba(0,0,0,.07);
}
.lp-bullets-box ul li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: var(--gold);
  font-weight: 700;
}
.lp-cta-box {
  text-align: center;
  padding-top: 1.25rem;
}
.lp-cta-box p { font-size: .85rem; color: var(--mid); margin-bottom: .25rem; }
.lp-cta-box > a:first-of-type {
  display: block;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--gold);
  margin-bottom: .25rem;
}

/* Why grid */
.lp-why {
  background: var(--dark);
  color: var(--white);
  padding: 5rem 0;
}
.lp-why .section-label { color: var(--gold-lt); }
.lp-why h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin: .5rem 0 2.5rem;
}
.lp-why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 2rem;
}
.lp-why-card { border-top: 2px solid var(--gold); padding-top: 1.25rem; }
.lp-why-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: .6rem; }
.lp-why-card p { font-size: .9rem; color: rgba(255,255,255,.7); line-height: 1.65; }

/* Process bar */
.lp-process { padding: 4rem 0; background: var(--light); }
.lp-process h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  margin: .5rem 0 2.5rem;
}
.lp-process-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}
.lp-step {
  text-align: center;
  padding: 1.5rem 1rem;
  background: var(--white);
  border-radius: var(--radius);
  border-top: 3px solid var(--gold);
}
.lp-step span {
  display: block;
  font-size: 2rem;
  font-weight: 700;
  color: var(--gold);
  font-family: var(--font-serif);
  margin-bottom: .5rem;
}
.lp-step p { font-size: .85rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; }

/* Mobile */
@media (max-width: 860px) {
  .lp-intro-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  .lp-bullets-box { position: static; }
  .lp-process-steps { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .lp-process-steps { grid-template-columns: 1fr 1fr; }
}
</style>
