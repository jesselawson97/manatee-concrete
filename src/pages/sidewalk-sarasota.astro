---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Commercial Sidewalks"
  serviceSlug="sidewalk"
  city="Sarasota"
  county="Sarasota County"
  headline="Commercial Sidewalk Contractor in Sarasota, FL"
  subheadline="ADA-compliant commercial sidewalks and walkways. New construction and replacement in Sarasota and Sarasota County."
  intro="Manatee Concrete builds and replaces commercial sidewalks in Sarasota that meet ADA standards and hold up to years of foot traffic. Safe, compliant, and built to last."
  body={[
    "From new walkway construction to replacing trip-hazard sections, we handle the full scope for retail, office, and mixed-use commercial properties across Sarasota County.",
    "Every sidewalk is graded for proper slope and drainage, jointed to control cracking, and finished to a clean, safe surface that reduces your liability."
  ]}
  bullets={[
    "New sidewalk & walkway construction",
    "Replacement of cracked & uneven sections",
    "ADA slope & detectable warning compliance",
    "Proper jointing & drainage grading",
    "Trip-hazard remediation",
    "Coordination with landscape & site plan"
  ]}
  heroImage="/images/service-sidewalk.jpg"
  heroAlt="Commercial sidewalk construction in Sarasota FL"
/>
