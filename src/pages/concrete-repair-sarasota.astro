---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Concrete Repair & Resurfacing"
  serviceSlug="concrete-repair"
  city="Sarasota"
  county="Sarasota County"
  headline="Commercial Concrete Repair in Sarasota, FL"
  subheadline="Crack repair, joint sealing, spall repair, and resurfacing that extends the life of your concrete. Serving Sarasota and Sarasota County."
  intro="Manatee Concrete provides commercial concrete repair and resurfacing in Sarasota that extends the life of your existing concrete and saves you the cost of full replacement."
  body={[
    "We repair cracks, seal joints, fix spalling and surface damage, and resurface failing slabs for parking lots, sidewalks, loading docks, and commercial floors throughout Sarasota County.",
    "We diagnose the underlying cause of the damage before we repair it, so the fix holds. And we'll give you a straight answer on whether repair or replacement is the smarter investment."
  ]}
  bullets={[
    "Crack repair & routing",
    "Joint sealing & caulking",
    "Spall & surface repair",
    "Full slab resurfacing",
    "Loading dock & ramp repair",
    "Honest repair-vs-replace assessment"
  ]}
  heroImage="/images/service-repair.jpg"
  heroAlt="Commercial concrete repair in Sarasota FL"
/>
