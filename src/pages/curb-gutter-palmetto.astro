---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Curb & Gutter"
  serviceSlug="curb-gutter"
  city="Palmetto"
  county="Manatee County"
  headline="Commercial Curb & Gutter Contractor in Palmetto, FL"
  subheadline="Curb and gutter installation and replacement that protects your property and meets code. Serving Palmetto and Manatee County."
  intro="Manatee Concrete provides commercial curb and gutter installation and replacement in Palmetto, FL. Proper drainage protects your pavement and building — we build it to last and to code."
  body={[
    "We handle new curb and gutter, replacement of failing sections, ADA ramps, and valley gutters. Every project is graded for proper water flow and coordinated with your site drainage plan.",
    "Licensed, insured, and familiar with Manatee County requirements — whether the work is standalone or part of a larger parking lot project."
  ]}
  bullets={[
    "New curb & gutter installation",
    "Replacement of failing sections",
    "Proper drainage grading",
    "ADA ramp construction",
    "Valley gutters & flumes",
    "Coordination with site drainage plan"
  ]}
  heroImage="/images/service-curb.jpg"
  heroAlt="Commercial curb and gutter in Palmetto FL"
/>
