---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Parking Lot Construction"
  serviceSlug="parking-lot"
  city="Bradenton"
  county="Manatee County"
  headline="Commercial Parking Lot Contractor in Bradenton, FL"
  subheadline="New parking lot construction and full-depth replacement for commercial properties in Bradenton and Manatee County."
  intro="Your parking lot is the first thing customers see. Manatee Concrete builds commercial parking lots in Bradenton that are properly graded, reinforced, and built to handle years of heavy vehicle traffic without cracking or settling."
  body={[
    "We handle every phase of commercial parking lot construction — from site grading and sub-base preparation through concrete pour, jointing, and sealing. Our work meets Manatee County code requirements and is coordinated with your civil engineer and site contractor.",
    "Whether you're building a new lot from scratch or replacing a failing asphalt lot with concrete, Manatee Concrete delivers a finished product that lasts decades with minimal maintenance."
  ]}
  bullets={[
    "Site grading & sub-base preparation",
    "Reinforced concrete slab construction",
    "Expansion joint layout & installation",
    "ADA parking space compliance",
    "Curb & gutter integration",
    "Sealing & line stripe coordination"
  ]}
  heroImage="/images/service-parking.jpg"
  heroAlt="Commercial parking lot construction in Bradenton FL"
/>
