---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Concrete Repair & Resurfacing"
  serviceSlug="concrete-repair"
  city="Venice"
  county="Sarasota County"
  headline="Commercial Concrete Repair in Venice, FL"
  subheadline="Crack repair, joint sealing, spall repair, and resurfacing that extends the life of your concrete. Serving Venice and Sarasota County."
  intro="Manatee Concrete provides commercial concrete repair and resurfacing in Venice, FL — extending the life of your existing concrete and avoiding the cost of full replacement."
  body={[
    "We repair cracks, seal joints, fix spalling and surface damage, and resurface failing slabs for parking lots, sidewalks, loading docks, and commercial floors across Sarasota County.",
    "We diagnose the root cause before repairing so the fix lasts — and we'll tell you honestly when repair makes sense versus when replacement is the better long-term value."
  ]}
  bullets={[
    "Crack repair & routing",
    "Joint sealing & caulking",
    "Spall & surface repair",
    "Full slab resurfacing",
    "Loading dock & ramp repair",
    "Honest repair-vs-replace assessment"
  ]}
  heroImage="/images/service-repair.jpg"
  heroAlt="Commercial concrete repair in Venice FL"
/>
