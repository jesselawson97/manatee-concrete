---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Curb & Gutter"
  serviceSlug="curb-gutter"
  city="Bradenton"
  county="Manatee County"
  headline="Commercial Curb & Gutter Contractor in Bradenton, FL"
  subheadline="Curb and gutter installation and replacement that protects your property and meets code. Serving Bradenton and Manatee County."
  intro="Proper curb and gutter is what keeps water off your parking lot and away from your building. Manatee Concrete installs commercial curb and gutter in Bradenton that's built to code and engineered for proper drainage."
  body={[
    "We handle new curb and gutter installation, replacement of failing sections, and ADA-compliant ramp construction. Every project is graded for proper water flow and coordinated with your site drainage plan.",
    "Whether it's part of a new parking lot or a standalone repair, our crews deliver clean, durable curb and gutter that meets Manatee County requirements."
  ]}
  bullets={[
    "New curb & gutter installation",
    "Replacement of failing sections",
    "Proper drainage grading",
    "ADA ramp construction",
    "Valley gutters & flumes",
    "Coordination with site drainage plan"
  ]}
  heroImage="/images/service-curb.jpg"
  heroAlt="Commercial curb and gutter in Bradenton FL"
/>
