---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Commercial Sidewalks"
  serviceSlug="sidewalk"
  city="Palmetto"
  county="Manatee County"
  headline="Commercial Sidewalk Contractor in Palmetto, FL"
  subheadline="ADA-compliant commercial sidewalks and walkways. New construction and replacement in Palmetto and Manatee County."
  intro="Manatee Concrete provides commercial sidewalk construction and replacement in Palmetto, FL. ADA-compliant, properly graded walkways that keep your property safe and code-compliant."
  body={[
    "We build new sidewalks, replace failing sections, and remediate trip hazards for commercial properties throughout Palmetto and Manatee County.",
    "Every walkway is graded for proper slope and drainage, correctly jointed, and finished to a clean, durable surface that reduces liability and meets ADA requirements."
  ]}
  bullets={[
    "New sidewalk & walkway construction",
    "Replacement of cracked & uneven sections",
    "ADA slope & detectable warning compliance",
    "Proper jointing & drainage grading",
    "Trip-hazard remediation",
    "Coordination with landscape & site plan"
  ]}
  heroImage="/images/service-sidewalk.jpg"
  heroAlt="Commercial sidewalk construction in Palmetto FL"
/>
