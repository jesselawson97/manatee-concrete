---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base
  title="Commercial Concrete Contractor Bradenton FL | Manatee Concrete"
  description="Manatee Concrete is a commercial concrete contractor serving Bradenton, Sarasota & Manatee County FL. Parking lots, driveways, curb & gutter, sidewalks, and concrete repair. Call 941-730-8491."
  canonical="https://manateeconcrete.com"
>
  <Nav />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/hero.jpg" alt="Commercial concrete work in Bradenton FL" loading="eager" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content container">
      <p class="hero-eyebrow">Commercial Concrete — Bradenton, FL</p>
      <h1>Built to <em>last.</em><br />Poured with precision.</h1>
      <p class="hero-sub">
        Manatee County's commercial concrete contractor for parking lots, driveways,
        curb &amp; gutter, and concrete repair. Serving Manatee &amp; Sarasota County.
      </p>
      <a href="#contact" class="btn btn-white">Get a Free Quote</a>
    </div>
  </section>

  <!-- Services -->
  <section class="services-strip" id="services">
    <div class="container">
      <span class="section-label">What We Do</span>
      <h2 class="section-title">Commercial Concrete Services</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-card-img"><img src="/images/service-parking.jpg" alt="Commercial parking lot construction" /></div>
          <div class="service-card-body">
            <h3>Parking Lots</h3>
            <p>New commercial parking lot construction and full-depth replacement. Properly graded, reinforced, and built to handle years of heavy use.</p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card-img"><img src="/images/service-driveway.jpg" alt="Commercial driveway contractor" /></div>
          <div class="service-card-body">
            <h3>Commercial Driveways</h3>
            <p>Heavy-duty commercial driveways for warehouses, retail centers, and business parks — designed for truck traffic and long-term durability.</p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card-img"><img src="/images/service-curb.jpg" alt="Curb and gutter installation" /></div>
          <div class="service-card-body">
            <h3>Curb &amp; Gutter</h3>
            <p>Commercial curb and gutter installation and replacement. Proper drainage solutions that protect your property and meet code requirements.</p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card-img"><img src="/images/service-sidewalk.jpg" alt="Commercial sidewalk construction" /></div>
          <div class="service-card-body">
            <h3>Sidewalks</h3>
            <p>ADA-compliant commercial sidewalks and walkways. New construction and replacement for retail, office, and mixed-use properties.</p>
          </div>
        </div>
        <div class="service-card">
          <div class="service-card-img"><img src="/images/service-repair.jpg" alt="Concrete repair and resurfacing" /></div>
          <div class="service-card-body">
            <h3>Concrete Repair &amp; Resurfacing</h3>
            <p>Crack repair, joint sealing, spall repair, and full resurfacing for aging commercial concrete. Extend the life of your investment.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="about" id="about">
    <div class="container">
      <div class="about-inner">
        <div class="about-img">
          <img src="/images/about.jpg" alt="Commercial concrete project in Manatee County" />
          <div class="about-img-accent"></div>
        </div>
        <div class="about-text">
          <span class="section-label">About Manatee Concrete</span>
          <h2 class="section-title">Bradenton's Commercial Concrete Experts</h2>
          <p>
            Manatee Concrete specializes exclusively in commercial concrete work across
            Manatee and Sarasota County. From new parking lot construction to concrete
            repair and resurfacing, we handle every scope with the precision and
            accountability that commercial properties demand.
          </p>
          <p>
            Every project is managed by an experienced superintendent with a vetted
            concrete crew. We coordinate directly with civil engineers, property managers,
            and general contractors to keep your project on schedule.
          </p>
          <br />
          <a href="#contact" class="btn btn-gold">Start Your Project</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why -->
  <section class="why">
    <div class="container">
      <span class="section-label">Why Manatee Concrete</span>
      <h2 class="section-title" style="color:var(--white)">Commercial Concrete Done Right</h2>
      <div class="why-grid">
        <div class="why-card">
          <h3>Commercial Only</h3>
          <p>We don't do residential driveways. Every project we take on is commercial — our process, crews, and pricing reflect that focus.</p>
        </div>
        <div class="why-card">
          <h3>Licensed &amp; Insured</h3>
          <p>Fully licensed in the state of Florida with general liability and workers' comp on every project. No shortcuts, no surprises.</p>
        </div>
        <div class="why-card">
          <h3>On Schedule</h3>
          <p>Concrete work delays everything downstream. We set realistic timelines and coordinate with your other trades from day one.</p>
        </div>
        <div class="why-card">
          <h3>Local to Manatee County</h3>
          <p>We know the local building departments, inspectors, and material suppliers — fewer delays and better pricing.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process" id="process">
    <div class="container">
      <span class="section-label">How We Work</span>
      <h2 class="section-title">Simple. Transparent. Delivered.</h2>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-num">1</div>
          <h3>Free Consultation</h3>
          <p>We visit your site, understand the scope, and answer your questions — no obligation.</p>
        </div>
        <div class="process-step">
          <div class="step-num">2</div>
          <h3>Detailed Proposal</h3>
          <p>A transparent, itemized quote with no hidden costs or vague allowances.</p>
        </div>
        <div class="process-step">
          <div class="step-num">3</div>
          <h3>Permitting</h3>
          <p>We handle all permit applications and inspections so you don't have to.</p>
        </div>
        <div class="process-step">
          <div class="step-num">4</div>
          <h3>Pour &amp; Finish</h3>
          <p>Experienced crews, quality materials, and a superintendent on site every day.</p>
        </div>
        <div class="process-step">
          <div class="step-num">5</div>
          <h3>Final Walkthrough</h3>
          <p>We walk the job with you at completion and don't consider it done until you do.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas We Serve -->
  <section class="areas">
    <div class="container">
      <span class="section-label">Areas We Serve</span>
      <h2 class="section-title">Commercial Concrete Across Manatee &amp; Sarasota County</h2>
      <div class="areas-grid">
        <div class="areas-col">
          <h3>Parking Lots</h3>
          <ul>
            <li><a href="/parking-lot-bradenton">Bradenton</a></li>
            <li><a href="/parking-lot-sarasota">Sarasota</a></li>
            <li><a href="/parking-lot-palmetto">Palmetto</a></li>
            <li><a href="/parking-lot-venice">Venice</a></li>
          </ul>
        </div>
        <div class="areas-col">
          <h3>Driveways</h3>
          <ul>
            <li><a href="/concrete-driveway-bradenton">Bradenton</a></li>
            <li><a href="/concrete-driveway-sarasota">Sarasota</a></li>
            <li><a href="/concrete-driveway-palmetto">Palmetto</a></li>
            <li><a href="/concrete-driveway-venice">Venice</a></li>
          </ul>
        </div>
        <div class="areas-col">
          <h3>Curb &amp; Gutter</h3>
          <ul>
            <li><a href="/curb-gutter-bradenton">Bradenton</a></li>
            <li><a href="/curb-gutter-sarasota">Sarasota</a></li>
            <li><a href="/curb-gutter-palmetto">Palmetto</a></li>
            <li><a href="/curb-gutter-venice">Venice</a></li>
          </ul>
        </div>
        <div class="areas-col">
          <h3>Sidewalks</h3>
          <ul>
            <li><a href="/sidewalk-bradenton">Bradenton</a></li>
            <li><a href="/sidewalk-sarasota">Sarasota</a></li>
            <li><a href="/sidewalk-palmetto">Palmetto</a></li>
            <li><a href="/sidewalk-venice">Venice</a></li>
          </ul>
        </div>
        <div class="areas-col">
          <h3>Concrete Repair</h3>
          <ul>
            <li><a href="/concrete-repair-bradenton">Bradenton</a></li>
            <li><a href="/concrete-repair-sarasota">Sarasota</a></li>
            <li><a href="/concrete-repair-palmetto">Palmetto</a></li>
            <li><a href="/concrete-repair-venice">Venice</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="container">
      <h2>Ready to Get Started?</h2>
      <p>Free on-site consultations for commercial concrete projects throughout Manatee &amp; Sarasota County.</p>
      <a href="#contact" class="btn btn-white">Request a Free Quote</a>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-inner">
        <div class="contact-info">
          <span class="section-label">Let's Talk</span>
          <h2>Get a Free Concrete Quote</h2>
          <p>
            Tell us about your project and we'll reach out within one business day
            to schedule a free on-site consultation.
          </p>
          <div class="contact-detail">
            <strong>Phone:</strong> <span>941-730-8491</span>
          </div>
          <div class="contact-detail">
            <strong>Email:</strong> <span>projects@gulfwayconstruction.com</span>
          </div>
          <div class="contact-detail">
            <strong>Service Area:</strong> <span>Manatee &amp; Sarasota County, FL</span>
          </div>
        </div>
        <form class="contact-form" method="POST" action="https://api.web3forms.com/submit">
          <input type="hidden" name="access_key" value="8e57c099-bf52-4809-b261-521a3afe7b05" />
          <input type="hidden" name="subject" value="Concrete Project Inquiry — Manatee Concrete" />
          <input type="hidden" name="redirect" value="https://manateeconcrete.com" />
          <div class="form-row">
            <input type="text" name="first-name" placeholder="First Name" required />
            <input type="text" name="last-name" placeholder="Last Name" required />
          </div>
          <input type="email" name="email" placeholder="Email Address" required />
          <input type="tel" name="phone" placeholder="Phone Number" />
          <select name="project-type">
            <option value="" disabled selected>Project Type</option>
            <option>Parking Lot</option>
            <option>Commercial Driveway</option>
            <option>Curb &amp; Gutter</option>
            <option>Sidewalk</option>
            <option>Concrete Repair / Resurfacing</option>
            <option>Other</option>
          </select>
          <textarea name="message" placeholder="Tell us about your project…"></textarea>
          <button type="submit">Send Message</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
</Base>
