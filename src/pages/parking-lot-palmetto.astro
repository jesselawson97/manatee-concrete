---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Parking Lot Construction"
  serviceSlug="parking-lot"
  city="Palmetto"
  county="Manatee County"
  headline="Commercial Parking Lot Contractor in Palmetto, FL"
  subheadline="New parking lot construction and full-depth replacement for commercial properties in Palmetto and Manatee County."
  intro="Manatee Concrete provides commercial parking lot construction in Palmetto, FL for property owners, developers, and businesses who need a durable, code-compliant lot built on time and on budget."
  body={[
    "We handle site grading, sub-base preparation, forming, concrete pour, expansion joints, and finish work — coordinated with your civil and site contractor from day one.",
    "Palmetto's commercial growth means more parking lots being built and more aging lots being replaced. Concrete is the right long-term investment — lower maintenance, longer lifespan, and better load capacity than asphalt."
  ]}
  bullets={[
    "Site grading & sub-base preparation",
    "Reinforced concrete slab construction",
    "Expansion joint layout & installation",
    "ADA parking space compliance",
    "Curb & gutter integration",
    "Sealing & line stripe coordination"
  ]}
  heroImage="/images/service-parking.jpg"
  heroAlt="Commercial parking lot construction in Palmetto FL"
/>
