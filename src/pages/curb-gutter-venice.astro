---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Curb & Gutter"
  serviceSlug="curb-gutter"
  city="Venice"
  county="Sarasota County"
  headline="Commercial Curb & Gutter Contractor in Venice, FL"
  subheadline="Curb and gutter installation and replacement that protects your property and meets code. Serving Venice and Sarasota County."
  intro="Manatee Concrete installs commercial curb and gutter in Venice, FL engineered for proper drainage and built to Sarasota County code. Keep water off your pavement and away from your building."
  body={[
    "We handle new installation, replacement of failing sections, ADA ramps, and valley gutters — all graded for correct water flow and coordinated with your site's drainage design.",
    "Clean lines, durable concrete, and full coordination with your other site work. One contractor accountable from start to finish."
  ]}
  bullets={[
    "New curb & gutter installation",
    "Replacement of failing sections",
    "Proper drainage grading",
    "ADA ramp construction",
    "Valley gutters & flumes",
    "Coordination with site drainage plan"
  ]}
  heroImage="/images/service-curb.jpg"
  heroAlt="Commercial curb and gutter in Venice FL"
/>
