---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Commercial Sidewalks"
  serviceSlug="sidewalk"
  city="Venice"
  county="Sarasota County"
  headline="Commercial Sidewalk Contractor in Venice, FL"
  subheadline="ADA-compliant commercial sidewalks and walkways. New construction and replacement in Venice and Sarasota County."
  intro="Manatee Concrete builds and replaces commercial sidewalks in Venice, FL — ADA-compliant, properly graded, and built to last. Reduce your liability and keep your property up to code."
  body={[
    "We handle new walkway construction, replacement of cracked sections, and trip-hazard remediation for retail, office, and mixed-use commercial properties across Sarasota County.",
    "Proper slope, drainage grading, correct jointing, and a clean finish on every project — coordinated with your landscape and site plan."
  ]}
  bullets={[
    "New sidewalk & walkway construction",
    "Replacement of cracked & uneven sections",
    "ADA slope & detectable warning compliance",
    "Proper jointing & drainage grading",
    "Trip-hazard remediation",
    "Coordination with landscape & site plan"
  ]}
  heroImage="/images/service-sidewalk.jpg"
  heroAlt="Commercial sidewalk construction in Venice FL"
/>
