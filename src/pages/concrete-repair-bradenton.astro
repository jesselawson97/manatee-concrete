---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Concrete Repair & Resurfacing"
  serviceSlug="concrete-repair"
  city="Bradenton"
  county="Manatee County"
  headline="Commercial Concrete Repair in Bradenton, FL"
  subheadline="Crack repair, joint sealing, spall repair, and resurfacing that extends the life of your concrete. Serving Bradenton and Manatee County."
  intro="Replacing concrete is expensive. Repairing it before it fails is smart. Manatee Concrete provides commercial concrete repair and resurfacing in Bradenton that extends the life of your existing investment for a fraction of replacement cost."
  body={[
    "We handle crack repair, joint sealing, spall and surface repair, and full resurfacing for parking lots, sidewalks, loading docks, and commercial slabs across Manatee County.",
    "Our team assesses the root cause of the damage — not just the symptoms — so the repair actually lasts. We'll tell you honestly when a repair makes sense and when replacement is the better long-term value."
  ]}
  bullets={[
    "Crack repair & routing",
    "Joint sealing & caulking",
    "Spall & surface repair",
    "Full slab resurfacing",
    "Loading dock & ramp repair",
    "Honest repair-vs-replace assessment"
  ]}
  heroImage="/images/service-repair.jpg"
  heroAlt="Commercial concrete repair in Bradenton FL"
/>
