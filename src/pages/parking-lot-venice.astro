---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Parking Lot Construction"
  serviceSlug="parking-lot"
  city="Venice"
  county="Sarasota County"
  headline="Commercial Parking Lot Contractor in Venice, FL"
  subheadline="New parking lot construction and full-depth replacement for commercial properties in Venice and Sarasota County."
  intro="Manatee Concrete delivers commercial parking lot construction in Venice, FL — properly engineered, reinforced concrete lots built to last in Florida's climate and handle the demands of commercial traffic."
  body={[
    "Venice's growing commercial market means more property owners investing in quality infrastructure. We handle the full scope from sub-base through finish, coordinating with your civil engineer and site contractor to deliver on time.",
    "Every lot we build meets Sarasota County code requirements and is designed with proper drainage, expansion joints, and ADA compliance built in from the start."
  ]}
  bullets={[
    "Site grading & sub-base preparation",
    "Reinforced concrete slab construction",
    "Expansion joint layout & installation",
    "ADA parking space compliance",
    "Curb & gutter integration",
    "Sealing & line stripe coordination"
  ]}
  heroImage="/images/service-parking.jpg"
  heroAlt="Commercial parking lot construction in Venice FL"
/>
