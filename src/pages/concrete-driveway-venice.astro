---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Commercial Concrete Driveways"
  serviceSlug="concrete-driveway"
  city="Venice"
  county="Sarasota County"
  headline="Commercial Concrete Driveway Contractor in Venice, FL"
  subheadline="Heavy-duty commercial driveways built for truck traffic and long-term durability. Serving Venice and Sarasota County."
  intro="Manatee Concrete builds commercial concrete driveways in Venice, FL engineered for the loads your business actually puts on them. Warehouse entrances, retail access drives, and fleet yards built to last."
  body={[
    "We design every driveway with the proper slab thickness, reinforcement, and sub-base for its intended use. Commercial driveways take far more abuse than residential — we build accordingly.",
    "From permit drawings through final finish, Manatee Concrete handles the full scope and coordinates with your site and civil contractors to keep the project moving on schedule."
  ]}
  bullets={[
    "Engineered for truck & heavy equipment loads",
    "Proper thickness & reinforcement specification",
    "Sub-base preparation & compaction",
    "Expansion & control joint layout",
    "Permit drawings & permitting",
    "Coordination with site & civil contractor"
  ]}
  heroImage="/images/service-driveway.jpg"
  heroAlt="Commercial concrete driveway in Venice FL"
/>
