---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Commercial Concrete Driveways"
  serviceSlug="concrete-driveway"
  city="Sarasota"
  county="Sarasota County"
  headline="Commercial Concrete Driveway Contractor in Sarasota, FL"
  subheadline="Heavy-duty commercial driveways built for truck traffic and long-term durability. Serving Sarasota and Sarasota County."
  intro="Manatee Concrete builds commercial concrete driveways in Sarasota that are designed for the demands of commercial use — not residential standards applied to a business setting."
  body={[
    "We engineer every commercial driveway with the right slab thickness, reinforcement, and sub-base for your specific traffic loads. Warehouse entrances, retail access drives, and fleet yards all have different requirements — we design accordingly.",
    "From permit drawings through final pour and finish, Manatee Concrete manages the full scope with a superintendent on site and full coordination with your other contractors."
  ]}
  bullets={[
    "Engineered for truck & heavy equipment loads",
    "Proper thickness & reinforcement specification",
    "Sub-base preparation & compaction",
    "Expansion & control joint layout",
    "Permit drawings & permitting",
    "Coordination with site & civil contractor"
  ]}
  heroImage="/images/service-driveway.jpg"
  heroAlt="Commercial concrete driveway in Sarasota FL"
/>
