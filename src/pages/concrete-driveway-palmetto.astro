---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Commercial Concrete Driveways"
  serviceSlug="concrete-driveway"
  city="Palmetto"
  county="Manatee County"
  headline="Commercial Concrete Driveway Contractor in Palmetto, FL"
  subheadline="Heavy-duty commercial driveways built for truck traffic and long-term durability. Serving Palmetto and Manatee County."
  intro="Manatee Concrete provides commercial concrete driveway construction in Palmetto, FL for warehouses, industrial facilities, retail centers, and business parks. Built to handle heavy loads and Florida weather."
  body={[
    "We handle everything from sub-base preparation and forming through pour, jointing, and final finish. Every driveway is engineered to the specific load requirements of your business — not a one-size-fits-all residential spec.",
    "Licensed, insured, and familiar with Manatee County permitting requirements. One contractor, full accountability from start to finish."
  ]}
  bullets={[
    "Engineered for truck & heavy equipment loads",
    "Proper thickness & reinforcement specification",
    "Sub-base preparation & compaction",
    "Expansion & control joint layout",
    "Permit drawings & permitting",
    "Coordination with site & civil contractor"
  ]}
  heroImage="/images/service-driveway.jpg"
  heroAlt="Commercial concrete driveway in Palmetto FL"
/>
