---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Concrete Repair & Resurfacing"
  serviceSlug="concrete-repair"
  city="Palmetto"
  county="Manatee County"
  headline="Commercial Concrete Repair in Palmetto, FL"
  subheadline="Crack repair, joint sealing, spall repair, and resurfacing that extends the life of your concrete. Serving Palmetto and Manatee County."
  intro="Manatee Concrete provides commercial concrete repair and resurfacing in Palmetto, FL — extending the life of your existing concrete and saving you the cost of premature replacement."
  body={[
    "We handle crack repair, joint sealing, spall and surface repair, and full resurfacing for parking lots, sidewalks, loading docks, and commercial slabs throughout Palmetto and Manatee County.",
    "We find the root cause before we repair, so the fix actually lasts — and we give you an honest assessment of whether repair or replacement makes more financial sense."
  ]}
  bullets={[
    "Crack repair & routing",
    "Joint sealing & caulking",
    "Spall & surface repair",
    "Full slab resurfacing",
    "Loading dock & ramp repair",
    "Honest repair-vs-replace assessment"
  ]}
  heroImage="/images/service-repair.jpg"
  heroAlt="Commercial concrete repair in Palmetto FL"
/>
