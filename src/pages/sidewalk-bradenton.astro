---
import ServiceCity from '../layouts/ServiceCity.astro';
---
<ServiceCity
  service="Commercial Sidewalks"
  serviceSlug="sidewalk"
  city="Bradenton"
  county="Manatee County"
  headline="Commercial Sidewalk Contractor in Bradenton, FL"
  subheadline="ADA-compliant commercial sidewalks and walkways. New construction and replacement in Bradenton and Manatee County."
  intro="Cracked, uneven sidewalks are a liability and a code violation. Manatee Concrete builds and replaces commercial sidewalks in Bradenton that are ADA-compliant, properly graded, and built to last."
  body={[
    "We construct new sidewalks, replace failing sections, and bring existing walkways up to ADA standards for retail centers, office parks, and mixed-use commercial properties throughout Manatee County.",
    "Every sidewalk we pour is graded for proper drainage and slope, jointed correctly to control cracking, and finished to a clean, safe walking surface."
  ]}
  bullets={[
    "New sidewalk & walkway construction",
    "Replacement of cracked & uneven sections",
    "ADA slope & detectable warning compliance",
    "Proper jointing & drainage grading",
    "Trip-hazard remediation",
    "Coordination with landscape & site plan"
  ]}
  heroImage="/images/service-sidewalk.jpg"
  heroAlt="Commercial sidewalk construction in Bradenton FL"
/>
